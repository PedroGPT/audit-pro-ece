{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "functions": {
    "api/generate-pdf.js": {
      "memory": 2048,
      "maxDuration": 10,
      "includeFiles": "logo.png"
    },
    "api/*.js": {
      "maxDuration": 10
    }
  }
}
